# ─────────────────────────────────────────────
# SUPABASE
# Get these from: supabase.com → your project → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# ANTHROPIC
# Get from: console.anthropic.com → API Keys
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────
# APIFY
# Get from: console.apify.com → Settings → Integrations
# ─────────────────────────────────────────────
APIFY_API_KEY=apify_api_your-key-here

# Actor IDs — copy from Apify Store URLs
# https://apify.com/apify/instagram-profile-scraper
APIFY_INSTAGRAM_PROFILE_ACTOR_ID=shu8hvrXbJbY3Eb9W

# https://apify.com/apify/instagram-post-scraper
APIFY_INSTAGRAM_POST_ACTOR_ID=IHHRXpuHMCLzFmB4C

# https://apify.com/quacker/twitter-scraper
APIFY_X_ACTOR_ID=a9LoFRtA0bJCeXHJl

# ─────────────────────────────────────────────
# CLIENT CONFIG (change per client deployment)
# ─────────────────────────────────────────────
CLIENT_INSTAGRAM_HANDLE=your_client_handle
CLIENT_X_HANDLE=your_client_x_handle

# Comma-separated, no spaces
CLIENT_NICHE_KEYWORDS=short term rental,airbnb,vacation rental,str investing

# Comma-separated Instagram handles to track as competitors (5-15)
COMPETITOR_HANDLES=competitor1,competitor2,competitor3

# ─────────────────────────────────────────────
# SECURITY
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────
CRON_SECRET=your-random-secret-here

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
